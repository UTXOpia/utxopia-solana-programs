{
  "name": "utxopia-contracts",
  "version": "0.1.0",
  "description": "UTXOpia Solana smart contracts (Pinocchio)",
  "scripts": {
    "build": "cargo build-sbf --features devnet",
    "build:devnet": "cargo build-sbf --features devnet",
    "build:localnet": "cargo build-sbf --features localnet",
    "build:mainnet": "cargo build-sbf",
    "deploy": "bun run scripts/deploy-localnet.ts",
    "deploy:localnet": "bun run scripts/deploy-localnet.ts",
    "deploy:localnet:skip": "bun run scripts/deploy-localnet.ts --skip-deploy",
    "deploy:devnet": "bun run scripts/deploy-devnet.ts",
    "deploy:devnet:init": "bun run scripts/deploy-devnet.ts --init-only",
    "test": "bun run tests/zvault.ts",
    "test:mocha": "npx ts-mocha -p ./tsconfig.json -t 120000 tests/**/*.ts",
    "test:demo": "bun run scripts/test-demo-flow.ts",
    "test:name": "bun run scripts/test-name-registry.ts",
    "test:all": "bun run scripts/test-all.ts",
    "test:all:devnet": "NETWORK=devnet bun run scripts/test-all.ts",
    "test:basic": "bun run scripts/test-all.ts",
    "test:basic:devnet": "NETWORK=devnet bun run scripts/test-all.ts",
    "test:devnet:all": "NETWORK=devnet bun run scripts/test-all.ts && NETWORK=devnet bun run scripts/test-joinsplit-proof.ts && NETWORK=devnet bun run scripts/test-user-flows.ts && NETWORK=devnet bun run scripts/test-redemption-lifecycle.ts",
    "test:redemption": "bun run scripts/test-redemption-lifecycle.ts",
    "test:redemption:devnet": "NETWORK=devnet bun run scripts/test-redemption-lifecycle.ts",
    "setup:devnet": "bun run scripts/devnet-setup.ts",
    "test:joinsplit": "bun run scripts/test-joinsplit-proof.ts",
    "test:joinsplit:devnet": "NETWORK=devnet bun run scripts/test-joinsplit-proof.ts",
    "setup:localnet": "bun run scripts/setup-localnet.ts",
    "test:flows": "bun run scripts/test-user-flows.ts",
    "test:flows:devnet": "NETWORK=devnet bun run scripts/test-user-flows.ts",
    "regtest:up": "docker compose -f ../docker-compose.regtest.yml up -d",
    "regtest:down": "docker compose -f ../docker-compose.regtest.yml down"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@utxopia/sdk": "file:../sdk",
    "chai": "^6.2.2",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "mocha": "^11.7.5",
    "react": "^19.0.0",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.0.0"
  }
}
