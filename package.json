{
  "name": "utxopia-contracts",
  "version": "0.1.0",
  "description": "UTXOpia Solana smart contracts (Pinocchio)",
  "scripts": {
    "build": "cargo build-sbf --features devnet",
    "build:devnet": "cargo build-sbf --features devnet",
    "build:localnet": "cargo build-sbf --features localnet",
    "build:mainnet": "cargo build-sbf",
    "check:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "cargo test",
    "test:unit": "cargo test && bun test tests/unit",
    "test:integration": "bun test tests/**/*.test.ts",
    "test:localnet": "bun scripts/e2e-localnet.ts",
    "test:regtest": "bun scripts/regtest-flow.ts",
    "relay:deposit": "bun scripts/relay-deposit.ts",
    "regtest:up": "docker compose -f ../docker-compose.regtest.yml up -d",
    "regtest:down": "docker compose -f ../docker-compose.regtest.yml down"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@utxopia/sdk": "github:UTXOpia/utxopia-sdk#main"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
